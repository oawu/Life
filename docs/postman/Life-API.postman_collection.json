          "name": "01 | Apple Sign In（isDev）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = JSON.parse(responseBody)",
                  "",
                  "if (data && data.token)",
                  "    postman.setEnvironmentVariable(\"--token\", data.token)",
                  "else",
                  "    throw Error('格式錯誤！')"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@test.com\",\n    \"isDev\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseurl}}api/auth/apple/callback",
